{
  "name": "react-router-fsd",
  "displayName": "React + React Router v7 (FSD)",
  "description": "React + React Router v7 (Remix 방식) + TypeScript + Feature-Sliced Design 아키텍처",

  "detection": {
    "required": ["react-router"],
    "optional": ["react", "react-dom", "typescript", "@react-router/dev"]
  },

  "architecture": {
    "type": "fsd",
    "description": "Feature-Sliced Design — 각 레이어는 아래쪽 레이어만 import 가능, 같은 레이어 내 슬라이스 간 cross-import 금지",
    "layers": {
      "order": ["shared", "entities", "features", "widgets", "pages", "app"],
      "rules": {
        "shared":   { "allowedImports": [] },
        "entities": { "allowedImports": ["shared"] },
        "features": { "allowedImports": ["shared", "entities"] },
        "widgets":  { "allowedImports": ["shared", "entities", "features"] },
        "pages":    { "allowedImports": ["shared", "entities", "features", "widgets"] },
        "app":      { "allowedImports": ["shared", "entities", "features", "widgets", "pages"] }
      },
      "descriptions": {
        "shared":   "재사용 가능한 유틸, UI 키트, 타입, 설정 (슬라이스 없음)",
        "entities": "비즈니스 엔티티 (예: task, user) — 모델, API, UI 포함",
        "features": "사용자 행동 단위 (예: create-task, change-status)",
        "widgets":  "여러 엔티티/기능을 조합한 독립 블록",
        "pages":    "라우트별 페이지 — 위젯과 기능을 조합",
        "app":      "앱 진입점, 라우팅, 전역 프로바이더"
      }
    },
    "extraRules": [
      "같은 레이어 내 슬라이스 간 직접 import 금지 (예: features/create-task → features/change-status 금지)",
      "각 슬라이스는 공개 API(index.ts)를 통해서만 외부에 노출",
      "shared는 슬라이스가 없고 세그먼트(ui, lib, api, config, types)로 구성"
    ]
  },

  "naming": {
    "slices":     "kebab-case (예: create-task, task-list)",
    "components": "PascalCase (예: TaskCard.tsx)",
    "hooks":      "camelCase + use 접두사 (예: useTaskList.ts)",
    "models":     "camelCase (예: task.ts, taskEvent.ts)",
    "types":      "PascalCase + Type/Props/State 접미사",
    "tests":      "원본명.test.ts(x)",
    "publicApi":  "index.ts (각 슬라이스의 공개 API)"
  },

  "scripts": {
    "lint:arch":  "npx tsx scripts/structural-test.ts",
    "doc:check":  "npx tsx scripts/doc-freshness.ts"
  },

  "devServer": {
    "command": "npm run dev",
    "port": 5173,
    "readyCheck": "curl -s -o /dev/null -w '%{http_code}' http://localhost:5173"
  },

  "pathAlias": "@/",
  "srcRoot": "src/",

  "testFramework": {
    "unit": "vitest",
    "e2e": "playwright"
  },

  "docFreshnessDays": 14
}
